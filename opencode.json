{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
      "read": "allow",
      "edit": "allow",
      "glob": "allow",
      "grep": "allow",
      "list": "allow",
      "bash": {
        "*": "ask",
        "git *": "allow",
        "rm *": "deny",
        "mvn test *": "allow",
        "mvn compile *": "allow"
      },
      "task": "allow",
      "skill": "allow",
      "todoread": "allow",
      "todowrite": "allow",
      "webfetch": "ask",
      "websearch": "ask",
      "codesearch": "ask",
      "external_directory": "ask",
      "doom_loop": "ask"
    },
    "provider": {
      "neogen": {
        "npm": "@ai-sdk/openai-compatible",
        "name": "Neogen",
        "options": {
          "baseURL": "https://neogen.neosoft.fr/api",
          "apiKey": "{env:NEOGEN_API_KEY}"
        },
        "models": {
          "swe-dev-minimax-m2-5": {
            "name": "dev-agentique"
          },
          "standard": {
            "name": "Standard"
          }
        }
      }
    },
    "enabled_providers": ["neogen"],
    "share": "disabled",
    "model": "neogen/swe-dev-minimax-m2-5",
    "mcp": {
      "context7":{
        "enabled": true,
        "type": "remote",
        "url": "https://mcp.context7.com/mcp"
      }
    }
  }
